# Hostinger / Apache config for the static export.

# Custom 404 page (generated by Next.js export)
ErrorDocument 404 /404.html

# Fingerprinted assets are immutable; HTML must always revalidate so a new
# deploy shows up immediately (the cache-bust for a static site).
<IfModule mod_headers.c>
  <FilesMatch "\.(woff2|js|css|webp|jpe?g|svg|png|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate, max-age=0"
  </FilesMatch>
</IfModule>

# LiteSpeed (Hostinger's web server) — don't serve stale pages from server cache.
<IfModule LiteSpeed>
  CacheDisable public /
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp        "access plus 1 year"
  ExpiresByType image/jpeg        "access plus 1 year"
  ExpiresByType image/png         "access plus 1 year"
  ExpiresByType image/svg+xml     "access plus 1 year"
  ExpiresByType text/css          "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType font/woff2        "access plus 1 year"
</IfModule>

# Compress text responses
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml \
    application/javascript application/json image/svg+xml
</IfModule>
